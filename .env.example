# --- Telegram Bot (notifiche + conferma acquisto) ---
# Crea il bot via @BotFather su Telegram, copia il token qui sotto.
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
# Tuo chat_id numerico (vedi README per come scoprirlo).
TELEGRAM_CHAT_ID=123456789

# --- Comportamento acquisto ---
# DRY_RUN=true esegue tutto tranne il click finale di conferma ordine.
DRY_RUN=true
# Prezzo massimo accettato in EUR. Se la pagina mostra un prezzo superiore -> nessun acquisto.
MAX_PRICE_EUR=6.00
# Ore di attesa per il pulsante di conferma su Telegram prima di abortire.
CONFIRM_TIMEOUT_HOURS=6
# Intervallo di polling getUpdates (secondi). 25 e' il long-poll massimo affidabile.
CONFIRM_POLL_SECONDS=25

# --- Override opzionali ---
# Forza un volume specifico (default: legge da state.json e incrementa di 1).
# TARGET_VOLUME=64
# Override del nome serie nella ricerca (default sotto).
SEARCH_QUERY_TEMPLATE=One Piece New Edition vol. {volume}
